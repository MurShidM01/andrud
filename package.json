{
  "name": "andrud",
  "version": "1.0.2",
  "description": "Modern Android project scaffolding CLI tool - Generate production-ready Android projects in seconds",
  "type": "module",
  "files": [
    "dist",
    "bin",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "andrud": "./bin/andrud.js"
  },
  "main": "./dist/cli/index.js",
  "types": "./dist/cli/index.d.ts",
  "keywords": [
    "android",
    "cli",
    "scaffolding",
    "generator",
    "kotlin",
    "java",
    "jetpack-compose",
    "ndk",
    "native",
    "project-template",
    "android-studio",
    "mobile-development"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:all": "tsc -b",
    "dev": "npm run build && node bin/andrud.js",
    "link": "npm run build && npm link",
    "test": "node --test"
  },
  "author": "MurShidM01",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MurShidM01/andrud.git"
  },
  "homepage": "https://github.com/MurShidM01/andrud#readme",
  "bugs": {
    "url": "https://github.com/MurShidM01/andrud/issues"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "cac": "^6.7.14",
    "ejs": "^3.1.10",
    "fs-extra": "^11.2.0",
    "gradient-string": "^2.0.2",
    "ora": "^8.0.1",
    "picocolors": "^1.0.1",
    "update-notifier": "^7.0.0",
    "validate-npm-package-name": "^4.0.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.12.12",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
